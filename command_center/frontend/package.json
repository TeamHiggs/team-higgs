{
  "name": "command-center-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "emctl command-center SPA — built to docs/design/command-center-v1.html against command_center/openapi.json.",
  "scripts": {
    "dev": "vite",
    "gen:api": "openapi-typescript ../openapi.json -o src/api/schema.d.ts",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.4.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
